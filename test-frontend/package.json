{
  "name": "test-frontend",
  "version": "1.0.0",
  "description": "Frontend dla projektu Headless Grav",
  "scripts": {
    "build": "npm-run-all build:tailwind build:sass",
    "build:tailwind": "tailwindcss -i ./src/css/tailwind-input.css -o ./public/css/tailwind-output.css --minify",
    "build:sass": "sass ./src/sass/main.scss:./public/css/main.css --style=compressed",
    "dev": "npm-run-all --parallel watch:tailwind watch:sass",
    "watch:tailwind": "tailwindcss -i ./src/css/tailwind-input.css -o ./public/css/tailwind-output.css --watch",
    "watch:sass": "sass --watch ./src/sass:./public/css"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.10",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.30",
    "sass": "^1.70.0",
    "tailwindcss": "^3.4.0"
  },
  "browserslist": [
    "last 2 versions",
    "> 1%",
    "not dead"
  ]
}