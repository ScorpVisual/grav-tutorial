{
  "name": "test-frontend",
  "version": "1.0.0",
  "description": "Frontend dla projektu Headless Grav",
"scripts": {
    "build": "npm-run-all build:tailwind build:sass",
    "build:tailwind": "tailwindcss -i ./src/css/tailwind-input.css -o ../user/themes/kocieTexty/dist/css/tailwind-output.css --minify",
    "build:sass": "sass ../user/themes/kocieTexty/sass:../user/themes/kocieTexty/dist/css --style=compressed",
    "watch:tailwind": "tailwindcss -i ./src/css/tailwind-input.css -o ../user/themes/kocieTexty/dist/css/tailwind-output.css --watch",
    "watch:sass": "sass --watch ../user/themes/kocieTexty/sass:../user/themes/kocieTexty/dist/css",
    "watch:browser": "browser-sync start --proxy \"localhost:8000\" --files \"../user/themes/kocieTexty/dist/css/*.css, ../user/themes/kocieTexty/templates/**/*.html.twig\"",
    "dev": "npm-run-all --parallel watch:*"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.10",
    "browser-sync": "^3.0.4",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.30",
    "sass": "^1.70.0",
    "tailwindcss": "^3.4.0"
  },
  "browserslist": [
    "last 2 versions",
    "> 1%",
    "not dead"
  ]
}
