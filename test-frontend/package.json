{
  "name": "test-frontend",
  "version": "1.0.0",
  "description": "Frontend dla projektu Headless Grav",
  "scripts": {
    "kocietexty:build:tailwind": "tailwindcss -i ./src/css/tailwind-input.css -o ../user/themes/kocieTexty/dist/css/tailwind-output.css --minify",
    "kocietexty:build:sass": "sass ../user/themes/kocieTexty/sass:../user/themes/kocieTexty/dist/css --style=compressed",
    "kocietexty:build": "npm-run-all kocietexty:build:tailwind kocietexty:build:sass",
    "kocietexty:watch:tailwind": "tailwindcss -i ./src/css/tailwind-input.css -o ../user/themes/kocieTexty/dist/css/tailwind-output.css --watch",
    "kocietexty:watch:sass": "sass --watch ../user/themes/kocieTexty/sass:../user/themes/kocieTexty/dist/css",
    "kocietexty:watch:browser": "browser-sync start --proxy \"localhost:8080\" --files \"../user/themes/kocieTexty/dist/css/*.css, ../user/themes/kocieTexty/**/*.twig\"",
    "kocietexty:dev": "npm-run-all --parallel kocietexty:watch:tailwind kocietexty:watch:sass kocietexty:watch:browser",
    "vktheme:build:tailwind": "tailwindcss -i ./src/css/tailwind-input.css -o ../user/themes/vk-theme/dist/css/tailwind-output.css --minify",
    "vktheme:build:sass": "sass ../user/themes/vk-theme/sass:../user/themes/vk-theme/dist/css --style=compressed",
    "vktheme:build": "npm-run-all vktheme:build:tailwind vktheme:build:sass",
    "vktheme:watch:tailwind": "tailwindcss -i ./src/css/tailwind-input.css -o ../user/themes/vk-theme/dist/css/tailwind-output.css --watch",
    "vktheme:watch:sass": "sass --watch ../user/themes/vk-theme/sass:../user/themes/vk-theme/dist/css",
    "vktheme:watch:browser": "browser-sync start --proxy \"localhost:8080\" --files \"../user/themes/vk-theme/dist/css/*.css, ../user/themes/vk-theme/**/*.twig\"",
    "vktheme:dev": "npm-run-all --parallel vktheme:watch:tailwind vktheme:watch:sass vktheme:watch:browser"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.10",
    "browser-sync": "^3.0.4",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.30",
    "sass": "^1.70.0",
    "tailwindcss": "^3.4.0"
  },
  "browserslist": [
    "last 2 versions",
    "> 1%",
    "not dead"
  ]
}
