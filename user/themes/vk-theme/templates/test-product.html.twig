{% extends 'partials/base.html.twig' %}
{% block content %}


{% set productVariants = [
    {
        title: "Wariant Standard - Ponadczasowa Elegancja",
        price: "5 499",
        size: "Pojedynczy",
        full_desc: "Nasz Wariant Standard to idealne połączenie klasycznego wzornictwa i wysokiej jakości materiałów. Zapewnia trwałość i estetyczny wygląd, będąc jednocześnie najbardziej ekonomicznym wyborem dla pojedynczego miejsca."
    },
    {
        title: "Wariant Standard - Ponadczasowa Elegancja",
        price: "8 000",
        size: "Podwójny",
        full_desc: "Wariant podwójny oferuje więcej przestrzeni, zachowując te same walory estetyczne i jakościowe. Jest to doskonałe rozwiązanie dla par, zapewniające harmonię i elegancję."
    },
    {
        title: "Wariant Standard - Ponadczasowa Elegancja",
        price: "12 499",
        size: "Rodzinny",
        full_desc: "Największy z naszych wariantów, zaprojektowany z myślą o grobowcach rodzinnych. Łączy w sobie majestatyczny wygląd z najwyższą jakością wykonania, aby godnie upamiętnić bliskich."
    }
] %}

<div class="relative w-full h-[600px] rounded-lg shadow-lg overflow-hidden pale-img-border product-img is-active">
    <img src="{{ theme_url }}/images/placeholders/test-prod/VK-nagrobki-120.jpg" alt="Obrazek dla produktu 1" class="w-full h-full object-cover">
    <div class="absolute inset-0 flex flex-col items-center justify-center p-4 text-white">
        <div class="product-img__mini--title mt-2 text-2xl font-semibold">
            PRODUCT - GRANITE WHITE TOMBSTONE POLISHED #1
        </div>
    </div>
</div>

<section class="lg:px-4 py-16 max-w-screen-xl mx-auto">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-start">
      <div>
        <img src="{{ theme_url }}/images/placeholders/test-prod/VK-nagrobki-125.jpg" alt="Renowacja starego nagrobka granitowego" class="w-full object-cover golden-img-border hard-shadow">
    </div>
    <div class="overflow-hidden h-full flex flex-col">
        <div class="p-0 flex flex-col flex-grow gap-4 md:p-6">
            <h2 class="text-3xl font-bold text-gray-800 underline--cherry lg:whitespace-nowrap">Nagrobek urnowy</h2>

            {# Przyciski generowane dynamicznie #}
            <div class="flex flex-col justify-between lg:flex-row gap-3">
                {% for variant in productVariants %}
                    <button
                        type="button"
                        class="variant-button btn-tertiary text-center text-gray-600 hover:text-gray-900 shrink-0 whitespace-nowrap {% if loop.first %}is-active{% endif %}"
                        data-price="{{ variant.price }}"
                        data-desc="{{ variant.full_desc }}"
                    >
                        {{ variant.size }}
                    </button>
                {% endfor %}
            </div>

            {# Zaktualizowane wyświetlanie ceny #}
            <div class="text-xl md:text-2xl font-bold mt-2 price-highlighted">
                Cena: <span class="c-white">od <span id="product-price">{{ productVariants[0].price }}</span> PLN</span>
            </div>

            {# Zaktualizowane wyświetlanie opisu #}
            <p id="product-description" class="text-gray-700 text-lg">
                {{ productVariants[0].full_desc }}
            </p>

            <div class="flex flex-col lg:flex-row gap-3 mt-auto">
                <a href="#szczegoly" class="btn-primary flex-grow text-center">
                    Zobacz realizacje
                </a>
                <a href="#kontakt" class="btn-cta flex-grow text-center">
                    Zamów produkt
                </a>
            </div>
        </div>
    </div>
</section>

{% set materials = [
    {
        name: "Biały granit",
        desc: "Elegancki i ponadczasowy, biały granit nadaje pomnikowi lekkości i klasy.",
        img: theme_url ~ "/images/textures/marble-white-1.jpg"
    },
    {
        name: "Czerwony granit",
        desc: "Wyrazisty i pełen charakteru, czerwony granit wyróżnia się na tle innych.",
        img: theme_url ~ "/images/textures/marble-red-1.jpg"
    },
    {
        name: "Czarny granit",
        desc: "Klasyczny i dostojny, czarny granit symbolizuje trwałość i elegancję.",
        img: theme_url ~ "/images/textures/marble-black-1.jpg"
    },
    {
        name: "Piaskowiec",
        desc: "Unikalny i szlachetny, piaskowiec dodaje kompozycji głębi i oryginalności.",
        img: theme_url ~ "/images/textures/limestone-1.jpg"
    }
] %}

<section class="py-4 lg:py-8">
    {# --- Nagłówek sekcji --- #}
    <div class="max-w-4xl mx-auto mb-16">
        <h1 class="text-3xl font-bold text-gray-800 mb-4 border-bot-cherry text-center">
            Dostępne kamienie
        </h1>
        <p>
            Specjalizujemy się w pracach cmentarnych, budowie nagrobków i renowacji pomników.
            Skontaktuj się w celu zapoznania się z pełną ofertą naszych usług - nasza strona pozostaje w budowie, ale jesteśmy dostępni telefonicznie i mailowo. 
        </p>
        <p>
            Uwaga! Ceny kamieni są zależne od aktualnych cen rynkowych. Dostępność i koszty mogą się różnić w zależności od dostawcy i regionu. 
            Prosimy o kontakt w celu uzyskania dokładnych informacji na temat cen i dostępności kamieni. 
        </p>
    </div>
    <div class="max-w-screen-xl mx-auto md:px-4 grid grid-cols-1 lg:grid-cols-2 lg:gap-20 items-center">

        <div class="relative flex items-center justify-center h-[350px]">
            <button data-dir="prev" class="carousel-btn shuffle-carousel__btn shuffle-carousel__btn--prev">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
            </button>

            <div id="carousel-container" class="w-full h-full flex items-center justify-center">
                {% for material in materials %}
                    <img src="{{ material.img }}"
                         alt="{{ material.name }}"
                         data-name="{{ material.name }}"
                         data-desc="{{ material.desc }}"
                         class="carousel-item rounded-lg  object-cover cursor-pointer">
                {% endfor %}
            </div>

            <button data-dir="next" class="carousel-btn shuffle-carousel__btn shuffle-carousel__btn--next">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </button>
        </div>

    <div id="materialInfo" class="p-2 lg:p-6 lg:ml-12">
        <h3 id="materialName" class="text-3xl font-bold mb-3 text-gray-800 transition-opacity duration-300 underline--cherry"></h3>
        <p id="materialDesc" class="text-gray-600 text-lg leading-relaxed transition-opacity duration-300"></p>
    </div>


    </div>
</section>
{% set galleryItems = [
    { image_filename: 'VK-nagrobki-120.jpg', title: 'Nagrobek Pojedynczy Klasyczny' },
    { image_filename: 'VK-nagrobki-124.jpg', title: 'Nagrobek Podwójny Nowoczesny' },
