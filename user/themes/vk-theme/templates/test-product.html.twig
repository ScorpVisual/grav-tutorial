            {% for item in faq_items %}
                {# Ustawiamy pierwszą pozycję jako domyślnie otwartą #}
                <div class="faq-item pick-a-card rounded-lg shadow-sm transition-all duration-300 {% if loop.first %}is-active{% endif %}">
                    
                    {# Nagłówek pytania (teraz jest klikalny w całości) #}
                    <div class="faq-question flex justify-between items-center p-5 cursor-pointer">
                        <h3 class="font-bold text-lg text-gray-800">
                            {{ item.question }}
                        </h3>
                        {# Ikona strzałki, która będzie się obracać #}
                        <svg class="faq-icon w-5 h-5 text-gray-500 transition-transform duration-300" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                        </svg>
                    </div>

                    {# Kontener na odpowiedź, który będzie animowany #}
                    <div class="faq-answer-content">
                        <p class="text-gray-600 p-5 pt-0">
                            {{ item.answer }}
                        </p>
                    </div>

                </div>
            {% endfor %}
        </div>
    </div>
</section>

{# GALLERY MODAL: #}
<div id="fullscreen-modal" class="is-hidden fixed inset-0 bg-black bg-opacity-80 z-50 flex items-center justify-center p-4 transition-opacity duration-300 ease-in-out opacity-0 reset-fadeIn">
    <button id="close-modal-btn" class="absolute top-5 right-5 text-white text-5xl font-bold z-50 hover:text-gray-300 transition-colors">&times;</button>
    <div class="relative overflow-hidden">
        <img id="fullscreen-image" src="" alt="Fullscreen product image" class="max-w-[90vw] max-h-[90vh] rounded-lg shadow-2xl">
        <div id="fullscreen-alt-text" class="product-img__mini--title mt-2 text-xl font-semibold">
            
        </div>
    </div>
</div>


{% endblock %}