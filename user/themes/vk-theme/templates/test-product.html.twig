<section
    class="content-switcher js-content-switcher max-w-7xl mx-auto p-4 md:p-6 lg:p-8"
    data-content-items='{{ product_variants|json_encode|raw }}'
>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="md:col-span-1">
            <h2 class="text-xl md:text-2xl font-bold text-gray-800 mb-8 underline--cherry">Nasze Warianty</h2>
            <div class="flex flex-col gap-3">
                {% for variant in product_variants %}
                    <div
                        class="content-switcher__card pick-a-card p-4 rounded-lg cursor-pointer transition-all duration-300 {% if loop.first %}--is-active{% endif %}"
                        data-index="{{ loop.index0 }}"
                        role="button" aria-pressed="{{ loop.first ? 'true' : 'false' }}" tabindex="0"
                    >
                        <h3 class="font-bold text-lg text-gray-900 underline--light-grey">{{ variant.name }}</h3>
                        <p class="text-sm text-gray-600">{{ variant.short_desc }}</p>
                    </div>
                {% endfor %}
            </div>
        </div>
        <div class="md:col-span-2">
            <div class="content-switcher__display black-gradient-down rounded-lg overflow-hidden h-full flex flex-col p-6">
                <img
                    src="{{ product_variants[0].image }}" alt="{{ product_variants[0].alt_text }}"
                    class="content-switcher__image content-switcher__fade-in w-full h-64 object-cover cherry-img-border mb-4 rounded-md"
                >
                <div class="flex flex-col flex-grow gap-4 text-white">
                    <h2 class="content-switcher__title content-switcher__fade-in text-3xl font-bold underline--gold">{{ product_variants[0].title }}</h2>
                    
                    <div class="content-switcher__price-wrapper text-xl md:text-2xl font-bold mt-2">
                       <span class="content-switcher__fade-in"> Cena: <span class="content-switcher__price c-pink">{{ product_variants[0].price }}</span>
                    </div>

                    <p class="content-switcher__description content-switcher__fade-in text-lg">{{ product_variants[0].full_desc }}</p>
                    <div class="flex flex-col lg:flex-row gap-3 mt-auto">
