                        <a href="#kontakt" class="btn-cta flex-grow text-center">Zamów Wariant</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>



{% set faq_items = [
    {
        question: "Jak mogę zamówić usługę?",
