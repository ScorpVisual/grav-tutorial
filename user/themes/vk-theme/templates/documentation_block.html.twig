{# Pobieramy zmienne dla czytelności #}
{% set title = page.header.title %}
{% set intro = page.header.intro_text %}
{% set sections = page.header.sections %}

<section class="px-4 py-16 max-w-screen-xl mx-auto">
    
    {# Używamy tutaj stylów, aby wizualnie odróżnić ten blok #}
    <div class="bg-gray-50 border border-gray-200 rounded-lg p-6 md:p-10 shadow-sm documentation-guide">

        {% if title %}
            <h2 class="text-3xl font-bold text-gray-800 border-bot-cherry mb-4">{{ title }}</h2>
        {% endif %}
        
        {% if intro %}
            <p class="text-lg text-gray-700 mb-6">{{ intro|nl2br }}</p>
        {% endif %}
        
        {% if sections is not empty %}
            <div class="space-y-8">
                {# Pętla przez główne sekcje (np. "1. Zakładka: Treść") #}
                {% for section in sections %}
                    <div class="documentation-section">
                        
                        <h3 class="text-2xl font-semibold text-gray-700 mb-2">{{ section.title }}</h3>
                        
                        {% if section.description %}
                            <p class="text-gray-600 mb-4">{{ section.description|nl2br }}</p>
                        {% endif %}
                        
                        {# Pętla przez listę pól w danej sekcji #}
                        {% if section.fields is not empty %}
                            <ul class="list-disc list-inside space-y-3 pl-2">
                                {% for field in section.fields %}
                                    <li>
                                        <strong class="text-gray-900">{{ field.name }}:</strong>
                                        <span class="text-gray-700">{{ field.help }}</span>
                                    </li>
                                {% endfor %}
                            </ul>
                        {% endif %}
                    </div>
                    
                    {# Dodajemy linię oddzielającą, ale nie po ostatnim elemencie #}
                    {% if not loop.last %}
                       <hr class="my-6 border-gray-300">
                    {% endif %}
                    
                {% endfor %}
            </div>
        {% endif %}
        
    </div>
</section>