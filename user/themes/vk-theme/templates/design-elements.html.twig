{% extends 'partials/base.html.twig' %}
{% block content %}
{% include 'partials/landing-tombstone.html.twig'%}

<section class="px-4 py-16 max-w-screen-xl mx-auto">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-start">
      <div>
        <img src="{{ theme_url }}/images/photos/kamieniarstwo-wisniewski-wlasciciel.jpg" alt="Renowacja starego nagrobka granitowego" class="w-full object-cover golden-img-border hard-shadow">
    </div>
    <div>
        <h1 class="text-3xl font-bold text-gray-800 mb-4 border-bot-cherry">
            <span class="c-cherry">Kamieniarstwo Wiśniewski:</span><br>
            Zaufany zakład kamieniarski na Śląsku
        </h1>
        <p class="text-lg text-gray-700">
              Od ponad 30 lat dostarczamy wysokiej jakości usługi kamieniarskie, specjalizując się w projektowaniu i wykonawstwie nagrobków dla klientów z Dąbrowy Górniczej i całego Śląska.
        </p>
        <p class="text-lg text-gray-700">
              Stawiamy na najwyższą jakość materiałów i precyzję pracy. Podstawą naszej działalności są niezachwiana solidność wykonania i szacunek dla rzemiosła. 
        </p>
                <div class="flex flex-col lg:flex-row gap-3 lg:col-start-1 lg:row-start-4">
                <a href="#main-content" class="btn-primary flex-grow text-center">
                    Nasze usługi
                </a>
                <a href="#main-content" class="btn-cta flex-grow text-center">
                    Skontaktuj się
                </a>
        </div>
    </div>
</section>

    <div class="flex section-header mx-auto lg:mt-8 ">
        <div class="section-header__content section-header__bg--golden-alt">
            <h3 class="text-xl md:text-2xl text-center font-semibold fill-letters-gold-section uppercase">PRODUKTY</h3>
        </div>
    </div>

{# --- PRODUKTY --- #}
{% set products = [
    {
        name: "Nagrobek Nowoczesny N-01",
        image: theme_url ~ "/images/placeholders/test-prod/VK-nagrobki-120.jpg",
        alt_text: "Nagrobek nowoczesny z białego granitu",
        price: "od 6 499 PLN",
        link: "#link-do-n01",
        full_desc: "Model N-01 to kwintesencja nowoczesnego designu. Charakteryzuje się prostą bryłą, wysokiej jakości polerowanym granitem i minimalistycznymi akcentami."
    },
    {
        name: "Nagrobek Klasyczny K-08",
        image: theme_url ~ "/images/placeholders/test-prod/VK-nagrobki-124.jpg",
        alt_text: "Nagrobek klasyczny z czarnego granitu",
        price: "od 5 999 PLN",
        link: "#link-do-k08",
        full_desc: "Klasyczny nagrobek K-08 to ponadczasowy wybór, który łączy w sobie tradycyjną formę z doskonałą jakością wykonania. Wykonany z trwałego, czarnego granitu."
    },
    {
        name: "Nagrobek Artystyczny A-12",
        image: theme_url ~ "/images/placeholders/test-prod/VK-nagrobki-129.jpg",
        alt_text: "Nagrobek artystyczny z rzeźbą",
        price: "od 14 999 PLN",
        link: "#link-do-a12",
        full_desc: "Ten model to prawdziwe dzieło sztuki kamieniarskiej. Łączy w sobie różne rodzaje granitu i zawiera ręcznie wykonaną rzeźbę, co czyni go unikalnym projektem."
    },
    {
        name: "Nagrobek Klasyczny K-09",
        image: theme_url ~ "/images/placeholders/test-prod/VK-nagrobki-130.jpg",
        alt_text: "Nagrobek klasyczny z czarnego granitu",
        price: "od 5 999 PLN",
        link: "#link-do-k09",
        full_desc: "Klasyczny nagrobek K-09 to ponadczasowy wybór, który łączy w sobie tradycyjną formę z doskonałą jakością wykonania. Wykonany z trwałego, czarnego granitu."
    },
    {
        name: "Nagrobek Klasyczny K-10",
        image: theme_url ~ "/images/placeholders/test-prod/VK-nagrobki-131.jpg",
        alt_text: "Nagrobek klasyczny z czarnego granitu",
        price: "od 5 999 PLN",
        link: "#link-do-k10",
        full_desc: "Klasyczny nagrobek K-10 to ponadczasowy wybór, który łączy w sobie tradycyjną formę z doskonałą jakością wykonania. Wykonany z trwałego, czarnego granitu."
    }
] %}

{% if products is not empty %}
<section class="py-12 lg:py-16 overflow-hidden">
  {# --- KONTENER GŁÓWNY KARUZELI "SHUFFLE" --- #}
<div class="shuffle-carousel js-shuffle-carousel">
    <div class="shuffle-carousel__track">
        {% for product in products %}
        <div class="shuffle-carousel__slide">
            {# Karta produktu .product-card pozostaje taka sama jak w wersji z nakładką #}
            <div class="product-card" style="background-image: url('{{ product.image }}');">
                <div class="product-card__main-content">
                    <h3 class="product-card__title">{{ product.name }}</h3>
                    <p class="product-card__price"><span class="c-pink">Cena:</span> {{ product.price }}</p>
                    <button class="product-card__expand-btn">ROZWIŃ</button>
                </div>
                <div class="product-card__details-overlay">
                    <button class="details-overlay__close-btn" aria-label="Zamknij szczegóły">&times;</button>
                    <div class="details-overlay__content">
                        {# <h3 class="product-card__title">{{ product.name }}</h3>
                        <p class="product-card__price">{{ product.price }}</p> #}
                        <p class="product-card__desc">{{ product.full_desc }}</p>
                        <div class="product-card__buttons">
                            <a href="{{ product.link }}" class="btn-primary">Zobacz realizacje</a>
                            <a href="#kontakt" class="btn-cta">Zamów wariant</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
    {# --- Przyciski nawigacyjne --- #}
    <button class="shuffle-carousel__btn shuffle-carousel__btn--prev">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
    </button>
    <button class="shuffle-carousel__btn shuffle-carousel__btn--next">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
    </button>
</div>
    <div class="max-w-screen-xl mx-auto px-4">
        {# --- Nagłówek sekcji --- #}
        <div class="max-w-3xl mx-auto text-center">
            <h2 class="text-3xl font-bold my-8 text-gray-800 border-bot-cherry">
                Nasze produkty
            </h2>
            <p class="text-gray-600">
                Powyżej prezentujemy wybrane projekty nagrobków, które mieliśmy przyjemność zrealizować dla naszych Klientów.
            </p>
        </div>
            <button class="btn-cta w-full max-w-xs mx-auto flex" >
        Zobacz wszystkie dostępne produkty
    </button>
    </div>
</section>
{% endif %}

   <div class="flex section-header mx-auto my-8">
        <div class="section-header__content section-header__bg--black">
            <h3 class="text-xl md:text-2xl text-center font-semibold fill-letters-gold-section uppercase">Usługi</h3>
        </div>
    </div>
<section>
    <div class="max-w-4xl mx-auto my-8 lg:py-8">
        <h1 class="text-3xl font-bold text-gray-800 mb-4 border-bot-cherry text-center">
            Co możemy dla Ciebie zrobić?
        </h1>
        <p>
            Specjalizujemy się w pracach cmentarnych, budowie nagrobków i renowacji pomników.
            Skontaktuj się w celu zapoznania się z pełną ofertą naszych usług - nasza strona pozostaje w budowie, ale jesteśmy dostępni telefonicznie i mailowo. 
        </p>
    </div>
</section>

{% set services = [
    {
        name: "Nagrobki na Zamówienie",
        short_desc: "Projektujemy i wykonujemy nagrobki z granitu i marmuru.",
        image: theme_url ~ "/images/placeholders/test-prod/VK-nagrobki-120.jpg",
        alt_text: "Nagrobek pojedynczy wykonany z jasnego granitu",
        title: "Indywidualne Projekty Nagrobków",
        price: "Wycena indywidualna",
        full_desc: "Specjalizujemy się w tworzeniu unikalnych nagrobków dopasowanych do Państwa oczekiwań. Oferujemy szeroki wybór kamieni, od klasycznych granitów po ekskluzywne marmury, oraz pomagamy w stworzeniu projektu, który godnie upamiętni bliską osobę."
    },
    {
        name: "Renowacja Pomników",
        short_desc: "Przywracamy blask starym i zniszczonym nagrobkom.",
        image: theme_url ~ "/images/placeholders/test-prod/VK-nagrobki-124.jpg",
        alt_text: "Odnowiony nagrobek podwójny z ciemnego kamienia",
        title: "Kompleksowa Renowacja i Konserwacja",
        price: "od 800 PLN",
        full_desc: "Z biegiem lat kamień traci swój pierwotny wygląd. Oferujemy profesjonalne usługi renowacji, w tym czyszczenie, impregnację, naprawę pęknięć oraz polerowanie. Zabezpieczamy pomniki przed działaniem czynników atmosferycznych, przywracając im dawną świetność."
    },
    {
        name: "Liternictwo i Galanteria",
        short_desc: "Dodawanie napisów, portretów oraz akcesoriów.",
        image: theme_url ~ "/images/placeholders/test-prod/VK-nagrobki-126.jpg",
        alt_text: "Nagrobek z ozdobnymi akcesoriami kamiennymi",
        title: "Dodatki, Które Tworzą Całość",
        price: "Wycena indywidualna",
        full_desc: "Oferujemy precyzyjne kucie i odnawianie liter, a także montaż galanterii nagrobkowej, takiej jak wazony, lampiony, krzyże czy podstawki. Wykonujemy również grawerowane portrety i sentencje, nadając pomnikom osobisty i unikalny charakter."
    },
    {
        name: "Otoczenie Grobu",
        short_desc: "Układanie kostki brukowej i montaż ławeczek.",
        image: theme_url ~ "/images/placeholders/test-prod/VK-nagrobki-129.jpg",
        alt_text: "Nagrobek z estetycznie zagospodarowanym otoczeniem",
        title: "Estetyczne Zagospodarowanie Otoczenia",
        price: "od 1500 PLN",
        full_desc: "Dbamy nie tylko o sam pomnik, ale również o jego otoczenie. Oferujemy profesjonalne układanie kostki brukowej lub płyt granitowych wokół grobu, co ułatwia utrzymanie czystości i podnosi estetykę miejsca. Montujemy również trwałe i eleganckie ławeczki."
    }
] %}

<section
    class="content-switcher js-content-switcher max-w-7xl mx-auto p-4 md:p-6 lg:p-8 white-gradient-down lg:mb-16"
    data-content-items='{{ services|json_encode|raw }}'
>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="md:col-span-1">
            <h2 class="text-xl md:text-2xl font-bold mb-8 underline--cherry">Nasze usługi</h2>
            <div class="flex flex-col gap-3">
                {% for service in services %}
                    <div
                        class="content-switcher__card pick-a-card p-4 rounded-lg cursor-pointer transition-all duration-300 {% if loop.first %}--is-active{% endif %}"
                        data-index="{{ loop.index0 }}"
                        role="button" aria-pressed="{{ loop.first ? 'true' : 'false' }}" tabindex="0"
                    >
                        <h3 class="font-bold text-lg underline--light-grey">{{ service.name }}</h3>
                        <p class="text-sm ">{{ service.short_desc }}</p>
                    </div>
                {% endfor %}
            </div>
        </div>
        <div class="md:col-span-2">
            <div class="content-switcher__display rounded-lg overflow-hidden h-full flex flex-col lg:p-6 text-grey-600">
                <img
                    src="{{ services[0].image }}" alt="{{ services[0].alt_text }}"
                    class="content-switcher__image content-switcher__fade-in w-full h-64 object-cover cherry-img-border mb-4 rounded-md"
                >
                <div class="flex flex-col flex-grow gap-4 ">
                    <h2 class="content-switcher__title content-switcher__fade-in text-3xl font-bold underline--cherry">{{ services[0].title }}</h2>
                    
                    <div class="content-switcher__price-wrapper text-xl md:text-2xl font-bold mt-2">
                       <span class="content-switcher__fade-in"> Cena: <span class="content-switcher__price c-cherry">{{ services[0].price }}</span>
                    </div>

                    <p class="content-switcher__description content-switcher__fade-in text-lg">{{ services[0].full_desc }}</p>
                    <div class="flex flex-col lg:flex-row gap-3 mt-auto">
                        <a href="#szczegoly" class="btn-primary flex-grow text-center">Zobacz realizacje</a>
                        <a href="#kontakt" class="btn-cta flex-grow text-center">Zamów Usługę</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>


{% endblock %}