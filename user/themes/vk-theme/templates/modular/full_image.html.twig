{# 1. Pobranie danych obrazu #}
{% set image_data = page.header.image|first %}
{% set image_name = image_data.name %}
{% set image = image_name ? page.media[image_name] : null %}

{# 2. Zmienne #}
{% set image_alt = page.header.image_alt %}
{% set caption = page.header.caption %}
{% set image_style = page.header.image_style|default('golden-border') %}
{% set section_id = page.header.section_id %}
{% set max_width = page.header.max_width|default('max-w-5xl') %}
{% set aspect_class = page.header.aspect_ratio|default('') %}
{% set max_height = page.header.max_height %}

{# 3. Kontener #}
{% set container_class = (max_width == 'full') ? 'max-w-full' : max_width ~ ' mx-auto' %}

{# 4. Klasy obrazu #}
{% set image_class = '' %}
{% if image_style == 'golden-border' %}
    {% set image_class = 'w-full golden-img-border hard-shadow' %}
{% elseif image_style == 'rounded' %}
    {% set image_class = 'w-full rounded-lg shadow-lg golden-img-border hard-shadow' %}
{% else %}
    {% set image_class = 'w-full' %}
{% endif %}

<section class="px-4 py-2" {% if section_id %}id="{{ section_id }}"{% endif %}>
    
    <figure class="{{ container_class }} m-0 p-0">

        {% if image %}
            <div class="flex justify-center w-full">
                <img 
                    src="{{ image.url }}"
                    alt="{{ image_alt|default(page.title) }}"
                    class="{{ image_class }} {{ aspect_class }} block h-auto object-cover"
                    {% if max_height and max_height > 0 %}
                        style="max-height: {{ max_height }}px;"
                    {% endif %}
                >
            </div>

            {% if caption %}
                <figcaption class="text-center text-gray-600 text-lg mt-4">
                    {{ caption }}
                </figcaption>
            {% endif %}
        {% endif %}

    </figure>

</section>
