{# Plik: partials/_gallery-modular.html.twig #}

{# Sprawdzamy, czy zmienna 'items' została przekazana i nie jest pusta #}
{% if items is defined and items is not empty %}
    <div class="lg:p-6">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {# 
              Używamy tutaj generycznej zmiennej 'items', 
              którą otrzymamy z zewnątrz.
            #}
            {% for item in items %}
                <div class="relative w-full h-64 rounded-lg shadow-lg overflow-hidden pale-img-border product-img cursor-pointer">
                    {# Ścieżka do obrazka może też być przekazywana jako zmienna, jeśli galerie są w różnych folderach! #}
                    <img src="{{ theme_url }}{{ item.image_filename }}" 
                         alt="{{ item.title }}" 
                         class="w-full h-full object-cover">
                    
                    <div class="absolute inset-0 flex flex-col items-center justify-center p-4 text-white bg-black bg-opacity-20">
                        <span class="product-img__mini--check text-lg font-bold tracking-widest">
                            OBEJRZYJ
                        </span>
                        <div class="product-img__mini--title mt-2 text-xl font-semibold">
                            {{ item.title }}
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>
{% else %}
    {# Ten fragment wyświetli się, jeśli przekażemy pustą tablicę lub nic nie przekażemy #}
    <p class="col-span-full text-center text-gray-500">
        Obecnie brak zdjęć w galerii.
    </p>
{% endif %}