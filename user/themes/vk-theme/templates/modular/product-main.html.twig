{% set variants = page.header.product_variants %}

{% if variants is not empty %}
<section class="lg:px-4 py-16 max-w-screen-xl mx-auto product-details-module">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center">

      {# --- ZDJĘCIE WARIANTU 1 --- #}
      <div>
          {% set firstImg = variants[0].img %}
          {% set firstImgUrl = ('http' in firstImg or '/' == firstImg|first) ? theme_url ~ firstImg : theme_url ~ '/images/products/' ~ firstImg %}
          
          <img src="{{ firstImgUrl }}"
               alt="{{ page.header.section_title|default(page.title) }}"
               class="w-full object-cover golden-img-border hard-shadow">
      </div>

      {# --- TREŚĆ - DEBUG OPISÓW --- #}
      <div class="overflow-hidden h-full flex flex-col">
          <div class="p-0 flex flex-col flex-grow gap-4 md:p-6">

              <h2 class="text-3xl font-bold text-gray-800 underline--cherry lg:whitespace-nowrap">
                  TEST WARIANTÓW
              </h2>

              {# --- KONTENER DEBUGUJĄCY --- #}
              <div class="flex flex-col gap-6 border-4 border-red-500 p-4 rounded-lg">
                  <p class="font-bold text-red-600">Widok testowy wszystkich wyrenderowanych opisów:</p>
                  
                  {% for variant in variants %}
                      <div class="border-b border-gray-300 pb-4">
                          <h3 class="font-bold text-xl mb-1">
                              Wariant {{ loop.index }: {{ variant.title }}
                          </h3>
                          <p class="text-sm text-gray-500 mb-2">
                              ID dla skryptu JS: <code class="bg-gray-200 px-1 rounded">desc-source-{{ loop.index }}</code>
                          </p>
                          
                          <div class="text-gray-700 text-lg prose bg-gray-50 p-4 rounded">
                              {{ variant.full_desc|markdown|raw }}
                          </div>
                      </div>
                  {% endfor %}
                  
              </div>

          </div>
      </div>

  </div>
</section>
{% endif %}