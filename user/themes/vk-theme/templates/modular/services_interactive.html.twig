<section class="max-w-7xl mx-auto p-0 sm:p-4 md:p-6 lg:p-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        
        {# Lewa kolumna - lista usług #}
        <div class="md:col-span-1">
            <h2 class="text-xl md:text-2xl font-bold text-gray-800 mb-8 underline--cherry">{{ page.header.sidebar_title }}</h2>
            <div class="flex flex-col gap-3">
                {% for service in page.header.services %}
                <div class="pick-a-card {% if loop.first %}is-active{% endif %}">
                    <h3 class="font-bold text-lg text-gray-900 underline--light-grey">{{ service.tab_title }}</h3>
                    <p class="text-sm text-gray-600">{{ service.tab_subtitle }}</p>
                </div>
                {% endfor %}
            </div>
        </div>

        {# Prawa kolumna - szczegóły (domyślnie pierwszej) usługi #}
        {# W prawdziwym projekcie, zawartość tutaj byłaby pusta i wypełniana przez JS #}
        {% set first_service = page.header.services|first %}
        <div class="md:col-span-2">
            <div class="white-marble-slab overflow-hidden h-full flex flex-col">
                {% set image = page.media[first_service.main_image] %}
                {% if image %}
                <img src="{{ image.url }}" alt="{{ first_service.main_title }}" class="w-full h-64 object-cover cherry-img-border mb-2">
                {% endif %}
                
                <div class="p-0 flex flex-col flex-grow gap-4 md:p-6">
                    <h2 class="text-3xl font-bold text-gray-800 underline--cherry">{{ first_service.main_title }}</h2>
                    <div class="text-xl md:text-2xl font-bold text-gray-900 mt-2">
                        Cena: <span class="c-cherry">{{ first_service.price }}</span>
                    </div>

                    <p class="text-gray-700 text-lg">
                        {{ first_service.description|nl2br }}
                    </p>

                    {% if first_service.buttons %}
                    <div class="flex flex-col lg:flex-row gap-3 mt-auto">
                        {% for button in first_service.buttons %}
                        <a href="{{ button.url }}" class="{{ button.class }}">
                            {{ button.text }}
                        </a>
                        {% endfor %}
                    </div>
                    {% endif %}
                </div>
            </div>
        </div>

    </div>
</section>