{% set features = [
        {
            icon: 'tombstone.svg',
            title: 'Wyselekcjonowane materiały',
            text: '<strong>Korzystamy wyłącznie z granitu pierwszego gatunku.</strong><br><br>Zyskujesz pewność, że nagrobek zachowa swoją strukturę i&nbsp;piękno mimo upływu lat. Tworzymy pomniki odporne na mróz wilgoć i słońce.',
            alt: 'Ikona jakości materiału'
        },
        {
            icon: 'tombstone.svg',
            title: 'Kunszt detalu',
            text: '<strong>Dbałość o detal to nasz znak rozpoznawczy.</strong> <br><br>Każde cięcie i&nbsp;rzeźbienie wykonujemy z&nbsp;najwyższą starannością, wydobywając z kamienia jego naturalne piękno i&nbsp;perfekcyjny&nbsp;połysk.',
            alt: 'Ikona precyzji wykonania'
        },
        {
            icon: 'tombstone.svg',
            title: 'Partnerskie podejście',
            text: '<strong>Jesteśmy po to, by słuchać i&nbsp;doradzać.</strong> <br><br>Poprowadzimy Cię przez cały proces - oferujemy fachowe wsparcie na każdym etapie powstawania nagrobka.',
            alt: 'Ikona gwarancji satysfakcji'
        }
    ] %}
<section class="py-8 lg:py-16">
    <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">
        {# --- Section Header --- #}
        <div class="max-w-4xl mx-auto">
            <h1 class="text-3xl font-bold text-gray-800 mb-4 border-bot-cherry text-center">
                Co nas wyróżnia?
            </h1>
            <p>
                <strong>Tworzymy w kamieniu historię, która przetrwa próbę czasu. </strong>
                Projektujemy unikalne wzory, budujemy trwałe nagrobki i przeprowadzamy kompleksowe konserwacje pomników, dbając o każdy detal struktury. 
                <strong>Skontaktuj się z nami i zapoznaj się z naszymi realizacjami.</strong>
            </p>
        </div>

        {# --- Features Grid --- #}
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 gap-y-8 py-8 lg:py-16">
            {% for feature in features %}
                <div class="p-4 flex flex-col items-center text-center h-full article-card hover-up-4">
                    <div class="flex-shrink-0 my-auto">
                        <div class="flex items-start justify-center h-16 w-16">
                            <img src="{{ theme_url }}/images/icons/{{ feature.icon }}" alt="{{ feature.alt }}">
                        </div>
                    </div>

                    <h3 class="text-xl font-semibold text-ink mb-3 min-h-[3.5rem] flex items-center justify-center text-center">
                        {{ feature.title }}
                    </h3>

                    <hr class="w-full hr-underline bg-cherry mb-3">

                    <p class="text-text-brown leading-relaxed grow">
                        {{ feature.text|raw }}
                    </p>
                </div>
            {% endfor %}
        </div>
    </div>
</section>
