<section class="py-8 lg:py-16">
    <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">
        {# --- Section Header --- #}
        <div class="max-w-4xl mx-auto">
            <h1 class="text-3xl font-bold text-gray-800 mb-4 border-bot-cherry text-center">
                Co nas wyróżnia?
            </h1>
            <p>
                Specjalizujemy się w pracach cmentarnych, budowie nagrobków i renowacji pomników.
                Skontaktuj się w celu zapoznania się z pełną ofertą naszych usług - nasza strona pozostaje w budowie, 
                ale jesteśmy dostępni telefonicznie i mailowo.
            </p>
        </div>

        {# --- Features Grid --- #}
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 gap-y-8 py-8 lg:py-16">
            {% for feature in features %}
                <div class="p-4 flex flex-col items-center text-center h-full article-card hover-up-4">
                    <div class="flex-shrink-0 my-auto">
                        <div class="flex items-start justify-center h-16 w-16">
                            <img src="{{ theme_url }}/images/icons/{{ feature.icon }}" alt="{{ feature.alt }}">
                        </div>
                    </div>

                    <h3 class="text-xl font-semibold text-ink mb-3 min-h-[3.5rem] flex items-center justify-center text-center">
                        {{ feature.title }}
                    </h3>

                    <hr class="w-full hr-underline bg-cherry mb-3">

                    <p class="text-text-brown leading-relaxed grow">
                        {{ feature.text }}
                    </p>
                </div>
            {% endfor %}
        </div>
    </div>
</section>
