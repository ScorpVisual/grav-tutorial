{# Zdefiniowanie zmiennej z CMS dla wygody 
{% set product_addons = page.header.product_addons %}

{% if product_addons is not empty %}
<section
    class="content-switcher js-content-switcher max-w-7xl mx-auto p-0 md:p-6 lg:p-8"
    data-content-items='{{ product_addons|json_encode|raw }}'
>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-start">
        <div class="md:col-span-1">
            <h2 class="text-xl md:text-2xl font-bold mb-8 underline--cherry">
                {{ page.header.section_title }}
            </h2>
            
            <button id="addon-drawer-trigger" type="button" class="w-full flex justify-between items-center p-4 rounded-lg pick-a-card transition-all duration-300 mb-3">
                <span id="current-addon-name" class="font-bold text-lg">{{ product_addons[0].name }}</span>
                <svg id="addon-drawer-icon" class="w-6 h-6 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
            </button>
            
            <div 
                id="addon-drawer-panel" 
                class="overflow-hidden transition-all duration-500 ease-in-out max-h-0 md:max-h-none md:overflow-visible"
            >
                <div class="flex flex-col gap-3 py-2">
                    {% for addon in product_addons %}
                        <div
                            class="content-switcher__card pick-a-card p-4 rounded-lg cursor-pointer transition-all duration-300 {% if loop.first %}--is-active{% endif %}"
                            data-index="{{ loop.index0 }}"
                            role="button" aria-pressed="{{ loop.first ? 'true' : 'false' }}" tabindex="0"
                        >
                            <h3 class="font-bold text-lg underline--light-grey">{{ addon.name }}</h3>
                            <p class="text-sm ">{{ addon.short_desc }}</p>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
        
        <div class="md:col-span-2">
            <div class="content-switcher__display rounded-lg overflow-hidden h-full flex flex-col lg:p-6 md:min-h-[52rem]">
                <img
                    src="{{ theme_url }}/{{ product_addons[0].image }}" alt="{{ product_addons[0].alt_text }}"
                    class="content-switcher__image content-switcher__fade-in w-full h-full object-cover cherry-img-border mb-4 rounded-md"
                >
                <div class="flex flex-col flex-grow gap-4">
                    <h2 class="content-switcher__title content-switcher__fade-in text-3xl font-bold underline--cherry">
                        {{ product_addons[0].title|default(product_addons[0].name) }}
                    </h2>
                    <div class="content-switcher__price-wrapper text-xl md:text-2xl font-bold mt-2">
                        <span class="content-switcher__fade-in"> Cena: <span class="content-switcher__price c-cherry">{{ product_addons[0].price }}</span>
                    </div>
                    <p class="content-switcher__description content-switcher__fade-in text-lg">
                        {{ product_addons[0].full_desc|nl2br }} 
                    </P>
                    <div class="flex flex-col lg:flex-row gap-3 mt-auto">
                        <a href="#szczegoly" class="btn-primary flex-grow text-center">Zobacz realizacje</a>
                        <a href="#kontakt" class="btn-cta flex-grow text-center">Zamów Dodatek</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endif %}
#}


{# 1. Pobieramy dane i definiujemy brakującą część ścieżki #}
{% set raw_addons = page.header.product_addons %}
{% set path_prefix = theme_url ~ '/images/products/addons/' %}

{# 2. FIX DLA JS: Tworzymy nową tablicę z pełnymi ścieżkami #}
{# Dzięki temu po kliknięciu w zakładki, skrypt JS też będzie znał poprawny adres #}
{% set product_addons = [] %}
{% for item in raw_addons %}
    {% set item_fixed = item|merge({'image': path_prefix ~ item.image}) %}
    {% set product_addons = product_addons|merge([item_fixed]) %}
{% endfor %}

{% if product_addons is not empty %}
    <div class="flex section-header mx-auto my-8">
        <div class="section-header__content section-header__bg--black-darkened ">
            <h3 class="text-xl md:text-2xl text-center font-semibold fill-letters-gold-section uppercase">
                {{ page.header.title|default('Galanteria') }}
            </h3>
        </div>
    </div>
<section
    class="content-switcher js-content-switcher max-w-7xl mx-auto p-0 md:p-6 lg:p-8"
    {# Tutaj przekazujemy już naprawioną tablicę z pełnymi ścieżkami #}
    data-content-items='{{ product_addons|json_encode|raw }}'
>


    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-start">
        {# LEWA KOLUMNA #}
        <div class="md:col-span-1">

            
            <button id="addon-drawer-trigger" type="button" class="w-full flex justify-between items-center p-4 rounded-lg pick-a-card transition-all duration-300 mb-3">
                <span id="current-addon-name" class="font-bold text-lg">{{ product_addons[0].name }}</span>
                <svg id="addon-drawer-icon" class="w-6 h-6 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
            </button>
            
            <div id="addon-drawer-panel" class="overflow-hidden transition-all duration-500 ease-in-out max-h-0 md:max-h-none md:overflow-visible">
                <div class="flex flex-col gap-3 py-2">
                    {% for addon in product_addons %}
                        <div
                            class="content-switcher__card pick-a-card p-4 rounded-lg cursor-pointer transition-all duration-300 {% if loop.first %}--is-active{% endif %}"
                            data-index="{{ loop.index0 }}"
                            role="button" aria-pressed="{{ loop.first ? 'true' : 'false' }}" tabindex="0"
                        >
                            <h3 class="font-bold text-lg underline--light-grey">{{ addon.name }}</h3>
                            <p class="text-sm ">{{ addon.short_desc }}</p>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
        
        {# PRAWA KOLUMNA #}
        <div class="md:col-span-2">
            <div class="content-switcher__display rounded-lg overflow-hidden h-full flex flex-col lg:p-6 md:min-h-[52rem]">
                
                {# FIX: Tutaj używamy już product_addons[0].image, który ma w sobie pełną ścieżkę z pętli wyżej #}
                <img
                    src="{{ product_addons[0].image }}" 
                    alt="{{ product_addons[0].alt_text }}"
                    class="content-switcher__image content-switcher__fade-in w-full object-cover cherry-img-border mb-4 rounded-md"
                >
                
                <div class="flex flex-col flex-grow gap-4">
                    <h2 class="content-switcher__title content-switcher__fade-in text-3xl font-bold underline--cherry">
                        {{ product_addons[0].title|default(product_addons[0].name) }}
                    </h2>
                    <div class="content-switcher__price-wrapper text-xl md:text-2xl font-bold mt-2">
                        <span class="content-switcher__fade-in"> Cena: <span class="content-switcher__price c-cherry">{{ product_addons[0].price }}</span></span>
                    </div>
                    <p class="content-switcher__description content-switcher__fade-in text-lg">
                        {{ product_addons[0].full_desc|nl2br }}
                    </p>
                    <div class="flex flex-col lg:flex-row gap-3 mt-auto">
                        <a href="#szczegoly" class="btn-primary flex-grow text-center">Zobacz realizacje</a>
                        <a href="#kontakt" class="btn-cta flex-grow text-center">Zamów Dodatek</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endif %}