<section class="hero-video relative flex items-center justify-center w-full min-h-[780px] text-center overflow-hidden">
    <div class="hero-overlay-animated"></div>

    <video
        playsinline
        autoplay
        muted
        loop
        poster="{{ theme_url }}/images/video/main-hero-poster.jpg"
        class="hero-video__video"
    >
        <source src="{{ theme_url }}/images/video/main-hero.webm" type="video/webm" />
        Twoja przeglądarka nie obsługuje tagu wideo.
    </video>

    {# --- KONTENER TREŚCI, TAKI JAK W CUSTOM HERO --- #}
    <div class="relative z-10 w-full px-4 mx-auto flex flex-col items-center max-w-[95%] md:max-w-2xl lg:max-w-[60%]">
        
        <h1 class="text-3xl sm:text-4xl md:text-6xl font-bold c-white drop-shadow-lg font-cormorant underline-cherry text-center leading-tight">
            JAKOŚĆ NA WIEKI
        </h1>

        <p class="text-base sm:text-lg md:text-xl mt-6 w-full max-w-3xl mx-auto c-white drop-shadow-md text-center leading-relaxed">
            Trwałe pomniki na solidnym fundamencie.
        </p>

        <div class="flex flex-col sm:flex-row gap-0.5 justify-center items-center w-full mt-10">
            <a href="{{ home_url }}#specjalnosc"
               class="btn-primary flex items-center justify-center text-center transition-all w-full sm:w-auto min-w-[240px]">
                Dowiedz się więcej
            </a>
            <a href="{{ home_url }}#kontakt"
               class="btn-cta flex items-center justify-center text-center transition-all w-full sm:w-auto min-w-[240px]">
                Kontakt
            </a>
        </div>
    </div>
</section>
