        link: '#impregnacja'
    }
] %}

{# --- GÓRNY NAGŁÓWEK (TREŚĆ ZE STAREGO KODU) --- #}
<div class="flex section-header mx-auto my-8">
    <div class="section-header__content section-header__bg--black">
        <h3 class="text-xl md:text-2xl text-center font-semibold fill-letters-gold-section uppercase">Usługi</h3>
    </div>
</div>
<section>
    <div class="max-w-4xl mx-auto my-8 lg:py-8">
        <h1 class="text-3xl font-bold text-gray-800 mb-4 border-bot-cherry text-center">
            Co możemy dla Ciebie zrobić?
        </h1>
        <p>
          Specjalizujemy się w budowie nagrobków granitowych oraz renowacji pomników <strong>na terenie Dąbrowy Górniczej i całego Śląska</strong>. 
          Zapewniamy fachowe wykonanie i doradztwo na każdym etapie realizacji, za którym stoi <strong>szacunek do drugiego człowieka i powierzonego nam zadania</strong>. 
        </p>
    </div>
</section>

{# --- GŁÓWNA SEKCJA (STRUKTURA NOWA, DANE STARE) --- #}
{# Używam struktury 'Product Addons', ale wstrzykuję zmienną 'services' #}
{% if services is not empty %}
<section
    class="content-switcher js-content-switcher max-w-7xl mx-auto p-0 md:p-6 lg:p-8 lg:mb-16"
    data-content-items='{{ services|json_encode|raw }}'
>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-start">
        {# LEWA KOLUMNA #}
        <div class="md:col-span-1">
            <h2 class="text-xl md:text-2xl font-bold mb-8 underline--cherry">
                Popularne usługi
            </h2>
            
            {# Przycisk szuflady (Drawer) - ID zachowane z działającego kodu dla JS #}
            <button id="addon-drawer-trigger" type="button" class="w-full flex justify-between items-center p-4 rounded-lg pick-a-card transition-all duration-300 mb-3">
                <span id="current-addon-name" class="font-bold text-lg">{{ services[0].name }}</span>
                <svg id="addon-drawer-icon" class="w-6 h-6 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
            </button>
            
            {# Panel szuflady - ID zachowane z działającego kodu #}
            <div 
                id="addon-drawer-panel" 
                class="overflow-hidden transition-all duration-500 ease-in-out max-h-0 md:max-h-none md:overflow-visible"
            >
                <div class="flex flex-col gap-3 py-2">
                    {% for service in services %}
                        <div
                            class="content-switcher__card pick-a-card p-4 rounded-lg cursor-pointer transition-all duration-300 {% if loop.first %}--is-active{% endif %}"
                            data-index="{{ loop.index0 }}"
                            role="button" aria-pressed="{{ loop.first ? 'true' : 'false' }}" tabindex="0"
                        >
                            <h3 class="font-bold text-lg underline--light-grey">{{ service.name }}</h3>
                            <p class="text-sm ">{{ service.short_desc }}</p>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
        
        {# PRAWA KOLUMNA #}
        <div class="md:col-span-2">
            <div class="content-switcher__display rounded-lg overflow-hidden h-full flex flex-col lg:p-6 text-grey-600 md:min-h-[52rem]">
                
                {# Obrazek: Usunięto 'theme_url/' z src, bo zmienna services już go zawiera #}
                <img
                    src="{{ services[0].image }}" alt="{{ services[0].alt_text }}"
                    class="content-switcher__image content-switcher__fade-in w-full h-64 md:h-80 object-cover cherry-img-border mb-4 rounded-md"
                >
                <div class="flex flex-col flex-grow gap-4">
                    <h2 class="content-switcher__title content-switcher__fade-in text-3xl font-bold underline--cherry">
                        {{ services[0].title }}
                    </h2>
                    
                    <div class="content-switcher__price-wrapper text-xl md:text-2xl font-bold mt-2">
                        <span class="content-switcher__fade-in"> Cena: <span class="content-switcher__price c-cherry">{{ services[0].price }}</span></span>
                    </div>
                    
                    <p class="content-switcher__description content-switcher__fade-in text-lg">
                        {{ services[0].full_desc|nl2br }}
                    </p>
                    
                    {# Przyciski - podmienione na te właściwe dla Usług #}
                    <div class="flex flex-col lg:flex-row gap-3 mt-auto">
                        <a href="{{ page.find('/uslugi').url }}{{ services[0].link }}" class="btn-primary flex-grow text-center">Dowiedz się więcej</a>
                        <a href="{{ page.find('/kontakt').url }}" class="btn-cta flex-grow text-center">Zamów Usługę</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endif %}

{# --- DOLNA SEKCJA (TREŚĆ ZE STAREGO KODU) --- #}
<section>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-start max-w-screen-xl mx-auto px-4 my-16">
    <div>
        <img src="{{ theme_url }}/images/photos/services-photo.jpg" alt="Renowacja starego nagrobka granitowego" class="w-full object-cover golden-img-border hard-shadow">
    </div>
    <div class="flex flex-col space-y-6">
        <h1 class="text-3xl font-bold text-gray-800 mb-2 border-bot-cherry">
            Nasze usługi
        </h1>
        <p class="text-lg text-gray-700">
            <strong>Zajmujemy się kompleksową renowacją i konserwacją nagrobków z granitu i&nbsp;astryka. </strong>
            Niezależnie od stopnia zmatowienia czy wieku pomnika, zapewniamy pełne wsparcie w procesie jego odnowienia. 
            Pomagamy dobrać odpowiednią technikę szlifowania, metody konserwacji oraz estetyczne wykończenie otoczenia grobu.         
        </p>
        <p class="text-lg text-gray-700">
            Każdą powierzchnię starannie wygładzamy i&nbsp;zabezpieczamy specjalistycznymi preparatami. 
            <strong>Oferujemy również usługę stałej opieki nad grobami</strong>, obejmującą regularne porządki i bieżące prace konserwacyjne. 
        </p>
        <a href="{{ page.find('/uslugi').url }}" class="btn-primary w-full flex justify-center">
            Zobacz wszystkie dostępne usługi
        </a>
    </div>
  </div>
</section>
 
 
 
 
 
 
 
