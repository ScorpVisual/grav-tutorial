{% set shortcut_buttons = [
    { 'url': '#', 'text': 'Link numer 1' },
    { 'url': '#', 'text': 'Link numer 2' },
    { 'url': '#', 'text': 'Link numer 3' },
    { 'url': '#', 'text': 'Link numer 4' },
    { 'url': '#', 'text': 'Link numer 5' },
    { 'url': '#', 'text': 'Link numer 6' },
    { 'url': '#', 'text': 'Link numer 7' },
    { 'url': '#', 'text': 'Link numer 8' },
    { 'url': '#', 'text': 'Link numer 9' },
    { 'url': '#', 'text': 'Link numer 10' },
    { 'url': '#', 'text': 'Link numer 11' },
    { 'url': '#', 'text': 'Link numer 12' },
    { 'url': '#', 'text': 'Link numer 13' },
    { 'url': '#', 'text': 'Link numer 14' },
    { 'url': '#', 'text': 'Link numer 15' },
    { 'url': '#', 'text': 'Link numer 16' },
    { 'url': '#', 'text': 'Link numer 17' },
    { 'url': '#', 'text': 'Link numer 18' },
    { 'url': '#', 'text': 'Link numer 19' },
    { 'url': '#', 'text': 'Link numer 20' }
] %}

<section class="relative js-shortcut-carousel-container">
    <div class="folder-flag bg-cherry text-white font-bold">Na skróty</div>
    
    {# Zmiana: dostosowanie odstępów (gap) i paddingu (p) dla różnych ekranów #}
    <div class="bg-white p-2 md:p-3 rounded-lg vkCard__red flex flex-nowrap gap-2 md:gap-3 items-center golden-img-border hard-shadow">
        
        {# Zmiana: przycisk ukryty na małych ekranach (hidden), widoczny od średnich (md:flex) #}
        <button class="shortcut-button shortcut-button__left shrink-0 hidden md:inline-flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
        </button>
        
        {# Zmiana: ten div jest teraz "okienkiem" do przewijania #}
        {# overflow-x-auto -> włącza przewijanie poziome #}
        {# Klasy [...] -> ukrywają wizualnie pasek przewijania we wszystkich przeglądarkach #}
        <div class="flex-grow overflow-x-auto [-ms-overflow-style:none] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">
            {# Zmiana: dostosowanie odstępów między przyciskami #}
            <div class="shortcut-carousel__track flex gap-3 md:gap-4">
                {% if shortcut_buttons is defined and shortcut_buttons is not empty %}
                    {% for button in shortcut_buttons %}
                        <a href="{{ button.url }}" class="btn-tertiary text-center text-white hover:text-gray-900 shrink-0 whitespace-nowrap">
                            {{ button.text }}
                        </a>
                    {% endfor %}
                {% else %}
                    <p class="text-gray-500 w-full text-center">Brak dostępnych skrótów.</p>
                {% endif %}
            </div>
        </div>
        
        {# Zmiana: przycisk ukryty na małych ekranach (hidden), widoczny od średnich (md:flex) #}
        <button class="shortcut-button shortcut-button__right shrink-0 hidden md:inline-flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
        </button>
    </div>
</section>