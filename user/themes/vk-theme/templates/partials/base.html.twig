<!DOCTYPE html>
<html>
<head>
    {% include 'partials/head.html.twig' %}
</head>
<body class="typography">
    <header class="relative">
        {% include 'partials/header.html.twig' %}
    </header>

    <div id="main-content" class="grid-container">
        <aside class="grid-container__sidebar">
            {% include 'partials/aside.html.twig' %}
        </aside>

        <main class="grid-container__main-content">
            {% block content %}{% endblock %}

            {% include 'partials/contact.html.twig' %}
        </main>
    </div>

    <footer class="grid-container__footer white-marble-slab">
        {% include 'partials/footer.html.twig' %}
    </footer>
</body>
</html>