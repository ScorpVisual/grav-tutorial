{# 1. Konfiguracja zmiennych #}
{% set hero_image_name = page.header.hero_image %}
{% set hero_image_url = hero_image_name ? url('theme://images/covers/' ~ hero_image_name) : null %}

{# 
   2. Logika przyciemnienia:
   - Sprawdzamy, czy w .md jest 'hero_overlay'.
   - Jeśli jest, używamy go. Jeśli nie, domyślnie ustawiamy 30 (czyli 30%).
   - Dzielimy przez 100, aby uzyskać format CSS (np. 0.3).
#}
{% set overlay_value = page.header.hero_overlay is defined ? page.header.hero_overlay : 30 %}
{% set overlay_css = overlay_value / 100 %}

<section 
    class="hero-section relative flex items-center justify-center w-full min-h-[780px] 
           text-center overflow-hidden bg-cover bg-center navbar-gradient-down" 
    style="{% if hero_image_url %}background-image: url('{{ hero_image_url }}');
    {% else %}background-color: #333;{% endif %}"
>
    {# 
       --- NAKŁADKA PRZYCIEMNIAJĄCA --- 
       Używamy stylu inline dla opacity, bo Tailwind nie obsługuje dynamicznych wartości
       zmiennych w klasach (np. opacity-[{{value}}]) w czasie rzeczywistym bez konfiguracji JIT.
    #}
    <div class="absolute top-0 left-0 w-full h-full bg-black z-0 pointer-events-none" 
         style="opacity: {{ overlay_css }};">
    </div>

    {# --- KONTENER TREŚCI --- #}
    <div class="relative z-10 w-full px-4 mx-auto flex flex-col items-center max-w-[95%] md:max-w-2xl lg:max-w-[60%]">
        
        {# TYTUŁ #}
        <h1 class="text-3xl sm:text-4xl md:text-6xl font-bold c-white drop-shadow-lg font-cormorant underline-cherry text-center leading-tight">
            {{ page.title }}
        </h1>

        {# PODTYTUŁ #}
        {% if page.header.hero_subtitle %}
            <p class="text-base sm:text-lg md:text-xl mt-6 w-full max-w-3xl mx-auto c-white drop-shadow-md text-center leading-relaxed">
                {{ page.header.hero_subtitle }}
            </p>
        {% endif %}

        {# BUTTONY #}
        {% if page.header.hero_buttons %}
            <div class="flex flex-col sm:flex-row gap-0.5 justify-center items-center w-full mt-10">
                {% for button in page.header.hero_buttons %}
                    <a href="{{ button.url }}" 
                       class="{{ button.class | default('btn-primary') }} 
                              flex items-center justify-center text-center transition-all 
                              w-full sm:w-auto min-w-[240px]">
                        {{ button.text }}
                    </a>
                {% endfor %}
            </div>
        {% endif %}
        
    </div>
</section>