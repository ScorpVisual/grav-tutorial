{# === POPRAWKA === #}
{# Pobieramy obrazek z naszego nowego, dedykowanego pola 'hero_image' #}
{% set hero_image = page.media[page.header.hero_image] %}

<section 
    class="hero-section relative flex items-center justify-center w-full min-h-[780px] text-center overflow-hidden bg-cover bg-center navbar-gradient-down" 
    style="{% if hero_image %}background-image: url('{{ hero_image.url }}');{% else %}background-color: #333;{% endif %}"
>
    <div class="absolute top-0 left-0 w-full h-full bg-black opacity-40"></div>

    <div class="relative z-10 px-2 sm:px-4">
        <h1 class="text-3xl sm:text-4xl md:text-6xl font-bold c-white drop-shadow-lg font-cormorant underline-cherry text-center leading-tight">
            {{ page.title }}
        </h1>

        {# Ten kod jest już poprawny i teraz zadziała #}
        {% if page.header.hero_subtitle %}
            <p class="text-base sm:text-md md:text-xl mt-4 max-w-[90vw] sm:max-w-3xl mx-auto c-white drop-shadow-md text-center leading-snug">
                {{ page.header.hero_subtitle }}
            </p>
        {% endif %}

        {# Ten kod jest już poprawny i teraz zadziała #}
        {% if page.header.hero_buttons %}
            <div class="flex flex-col sm:flex-row gap-4 justify-center mt-8">
                {% for button in page.header.hero_buttons %}
                    <a href="{{ button.url }}" class="{{ button.class | default('btn-primary') }}">{{ button.text }}</a>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</section>