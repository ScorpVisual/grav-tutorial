<meta name="viewport" content="width=device-width, initial-scale=1" />

<title>
    {% if page.header.seo_title %}
        {{ page.header.seo_title|e('html') }}
    {% else %}
        {% if page.title %}{{ page.title|e('html') }} | {% endif %}{{ site.title|e('html') }}
    {% endif %}
</title>

