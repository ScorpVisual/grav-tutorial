<meta name="description" content="{% if page.header.full_desc %}{{ page.header.full_desc|striptags|e('html') }}{% else %}{{ site.metadata.description|e('html') }}{% endif %}">

{# --- OPEN GRAPH --- #}
<meta property="og:url" content="{{ page.url(true) }}">
<meta property="og:type" content="website">
<meta property="og:title" content="{% if page.header.seo_title %}{{ page.header.seo_title|e('html') }}{% else %}{{ page.title|e('html') }} | {{ site.title|e('html') }}{% endif %}">
<meta property="og:description" content="{% if page.header.full_desc %}{{ page.header.full_desc|truncate(160)|striptags|e('html') }}{% else %}{{ site.metadata.description|e('html') }}{% endif %}">

<meta property="og:image" content="https://kamieniarstwowisniewski.pl/user/themes/vk-theme/images/og-image.jpg">
<meta property="og:image:secure_url" content="https://kamieniarstwowisniewski.pl/user/themes/vk-theme/images/og-image.jpg">
<meta property="og:image:type" content="image/jpeg">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<meta property="og:image:alt" content="Kamieniarstwo Wiśniewski - Nagrobki i usługi kamieniarskie">

{# --- TWITTER CARDS --- #}
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{% if page.header.seo_title %}{{ page.header.seo_title|e('html') }}{% else %}{{ page.title|e('html') }}{% endif %}">
<meta name="twitter:description" content="{% if page.header.full_desc %}{{ page.header.full_desc|truncate(160)|striptags|e('html') }}{% else %}{{ site.metadata.description|e('html') }}{% endif %}">
<meta name="twitter:image" content="{{ url('theme://images/og-image.jpg', true) }}">
<link rel="canonical" href="{{ page.url(true) }}" />
{# Favicon w formacie SVG #}
<link rel="icon" href="{{ url('theme://images/icons/favico.svg') }}" type="image/svg+xml">
<link rel="shortcut icon" href="{{ url('theme://images/icons/favico.svg') }}" type="image/svg+xml">
<link rel="preload" href="{{ url('theme://dist/css/main.css') }}" as="style">
