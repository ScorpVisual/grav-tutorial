
   <div class="flex section-header mx-auto my-8">
        <div class="section-header__content section-header__bg--golden">
            <h3 class="text-xl md:text-2xl text-center font-semibold fill-letters-gold-section uppercase">Realizacje</h3>
        </div>
    </div>

{% set galleryItems = [
    { image_filename: 'tomb-featured-1.jpg', title: 'Nagrobek Podwójny Nowoczesny' },
    { image_filename: 'tomb-featured-2.jpg', title: 'Nagrobek Pojedynczy Klasyczny' },
    { image_filename: 'tomb-featured-3.jpg', title: 'Grobowiec Rodzinny z Granitu' },
    { image_filename: 'tomb-featured-4.jpg', title: 'Pomnik z Czarnym Krzyżem' },
    { image_filename: 'tomb-featured-5.jpg', title: 'Nagrobek Urnowy Jasny' },
    { image_filename: 'tomb-featured-6.jpg', title: 'Renowacja starego pomnika' },
    { image_filename: 'tomb-featured-7.jpg', title: 'Nagrobek Urnowy Jasny' },
    { image_filename: 'tomb-featured-8.jpg', title: 'Nagrobek Pojedynczy Klasyczny' },
    { image_filename: 'tomb-featured-9.jpg', title: 'Nagrobek Podwójny Nowoczesny' },
    { image_filename: 'tomb-featured-10.jpg', title: 'Renowacja starego pomnika' },
    { image_filename: 'tomb-featured-11.jpg', title: 'Grobowiec Rodzinny z Granitu' },
    { image_filename: 'tomb-featured-12.jpg', title: 'Pomnik z Czarnym Krzyżem' }
] %}

<section>
    <div class="max-w-4xl mx-auto">
        <h1 class="text-3xl font-bold text-gray-800 mb-4 border-bot-cherry text-center">
            Galeria 
        </h1>
        <p>
            Specjalizujemy się w pracach cmentarnych, budowie nagrobków i renowacji pomników.
            Skontaktuj się w celu zapoznania się z pełną ofertą naszych usług - nasza strona pozostaje w budowie, ale jesteśmy dostępni telefonicznie i mailowo. 
        </p>
    </div>
    <div class="lg:p-6">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">

            {# 
              2. PĘTLA FOR W TWIGU
              Iterujemy po każdym elemencie w tablicy `galleryItems`.
              Każdy element jest dostępny pod zmienną `item`.
            #}
            {% for item in galleryItems %}
                <div class="relative w-full h-64 rounded-lg shadow-lg overflow-hidden pale-img-border product-img cursor-pointer">
                    <img src="{{ theme_url }}/images/products/featured/{{ item.image_filename }}" 
                         alt="{{ item.title }}" 
                         class="w-full h-full object-cover">
                    
                    <div class="absolute inset-0 flex flex-col items-center justify-center p-4 text-white bg-black bg-opacity-20">
                        <span class="product-img__mini--check text-lg font-bold tracking-widest">
                            OBEJRZYJ
                        </span>
                        <div class="product-img__mini--title mt-2 text-xl font-semibold">
                            {{ item.title }}
                        </div>
                    </div>
                </div>
            {% else %}
                <p class="col-span-full text-center text-gray-500">
                    Obecnie brak zdjęć w galerii.
                </p>
            {% endfor %}
            
        </div>
    </div>
</section>
