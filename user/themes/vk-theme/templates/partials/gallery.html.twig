

{% set galleryItems = [
    { image_filename: 'tomb-featured-1.jpg', title: 'Nagrobek z indywidualnym projektem' },
    { image_filename: 'tomb-featured-2.jpg', title: 'Nagrobek dwukolorowy na trumny' },
    { image_filename: 'tomb-featured-3.jpg', title: 'Nagrobek jasny z czarną płytą' },
    { image_filename: 'tomb-featured-4.jpg', title: 'Podwójny pomnik z krawatem' },
    { image_filename: 'tomb-featured-5.jpg', title: 'Jednopłytowy z napisówką stojącą' },
    { image_filename: 'tomb-featured-6.jpg', title: 'Sarkofag z napisówką piaskowaną' },
    { image_filename: 'tomb-featured-7.jpg', title: 'Pomnik typu amerykańskiego z książką' },
    { image_filename: 'tomb-featured-8.jpg', title: 'Prosty sarkofag na urny' },
    { image_filename: 'tomb-featured-9.jpg', title: 'Pomnik z ciemnego granitu z ławeczką' },
    { image_filename: 'tomb-featured-14.jpg', title: 'Urnowy sarkofag z rzeźbą' },
    { image_filename: 'tomb-featured-13.jpg', title: 'Nagrobek z podwójną płytą' },
    { image_filename: 'tomb-featured-12.jpg', title: 'Dwupłytowy pomnik na trumny' }
] %}

<section>
    <div class="max-w-4xl mx-auto">
        <h1 class="text-3xl font-bold text-gray-800 mb-4 border-bot-cherry text-center">
            Galeria 
        </h1>
        <p>
            Specjalizujemy się w pracach cmentarnych, budowie nagrobków i renowacji pomników.
            Skontaktuj się w celu zapoznania się z pełną ofertą naszych usług - nasza strona pozostaje w budowie, ale jesteśmy dostępni telefonicznie i mailowo. 
        </p>
    </div>
    <div class="lg:p-6">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">

            {# 
              2. PĘTLA FOR W TWIGU
              Iterujemy po każdym elemencie w tablicy `galleryItems`.
              Każdy element jest dostępny pod zmienną `item`.
            #}
            {% for item in galleryItems %}
                <div class="relative w-full h-64 rounded-lg shadow-lg overflow-hidden pale-img-border product-img cursor-pointer">
                    <img src="{{ theme_url }}/images/products/featured/{{ item.image_filename }}" 
                         alt="{{ item.title }}" 
                         class="w-full h-full object-cover">
                    
                    <div class="absolute inset-0 flex flex-col items-center justify-center p-4 text-white bg-black bg-opacity-20">
                        <span class="product-img__mini--check text-lg font-bold tracking-widest">
                            OBEJRZYJ
                        </span>
                        <div class="product-img__mini--title mt-2 text-xl font-semibold">
                            {{ item.title }}
                        </div>
                    </div>
                </div>
            {% else %}
                <p class="col-span-full text-center text-gray-500">
                    Obecnie brak zdjęć w galerii.
                </p>
            {% endfor %}
            
        </div>
    </div>
</section>
