<div class="max-w-7xl mx-auto px-6 pt-16 pb-8">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 mb-10">

        {# --- LOGO I OPIS --- #}
        <div class="sm:col-span-2 lg:col-span-1">
            <div class="mb-6 flex justify-center lg:justify-start">
                <img src="{{ theme_url }}/images/brand/full-logotype-vertical.svg" class="h-auto w-32" alt="Logo">
            </div>
            <p class="text-md leading-relaxed mb-4 text-left">
                30 lat tradycji w wykonawstwie nagrobków dla klientów z&nbsp;Dąbrowy Górniczej i&nbsp;całego Śląska.
            </p>
        </div>

        {# --- NAGROBKI (Zaktualizowane) --- #}
        <div>
            <h4 class="text-lg font-medium c-ink border-bot-cherry mb-4">Nagrobki</h4>
            <ul class="space-y-2 text-sm">
                <li><a href="{{ pages.find('/produkty').url }}" class="text-gray-700 hover:c-cherry transition-colors link-hover-fill">Postawienie pomnika</a></li>
                <li><a href="{{ pages.find('/liternictwo-i-zdobienia').url }}" class="text-gray-700 hover:c-cherry transition-colors link-hover-fill">Dopiski liter</a></li>
                <li><a href="{{ pages.find('/galanteria-nagrobkowa').url }}" class="text-gray-700 hover:c-cherry transition-colors link-hover-fill">Montaż wazonów i dodatków</a></li>
                <li><a href="{{ pages.find('/liternictwo-i-zdobienia').url }}#malowanie" class="text-gray-700 hover:c-cherry transition-colors link-hover-fill">Malowanie liter</a></li>
            </ul>
        </div>

        {# --- USŁUGI (Nowe / Uzupełnione) --- #}
        <div>
            <h4 class="text-lg font-medium c-ink border-bot-cherry mb-4">Usługi</h4>
            <ul class="space-y-2 text-sm">
                {% set uslugi_path = pages.find('/uslugi').url %}
                <li>
                    <a href="{{ uslugi_path }}#wylewki" class="text-gray-700 hover:c-cherry transition-colors link-hover-fill">Wylewki i płytki</a>
                </li>
                <li>
                    <a href="{{ uslugi_path }}#remonty" class="text-gray-700 hover:c-cherry transition-colors link-hover-fill">Przebudowa pomnika</a>
                </li>
                <li>
                    <a href="{{ uslugi_path }}#impregnacja" class="text-gray-700 hover:c-cherry transition-colors link-hover-fill">Szlifowanie i konserwacja</a>
                </li>
                <li>
                    <a href="{{ uslugi_path }}#opieka" class="text-gray-700 hover:c-cherry transition-colors link-hover-fill">Sprzątanie i opieka nad grobem</a>
                </li>
            </ul>
        </div>

        {# --- KONTAKT --- #}
        <div>
            <h4 class="text-lg font-medium c-ink border-bot-cherry mb-4">Informacje</h4>
            <ul class="space-y-2 text-sm">
                <li>
                    <a href="tel:+4892182400684" class="text-gray-700 hover:c-cherry transition-colors link-hover-fill">
                        Telefon: <span class="ltr:inline rtl:hidden text-nowrap" style="unicode-bidi:bidi-override; direction: rtl;" > 921 824 006 84+</span>
                    </a>
                </li>
                <li>
                    <a href="mailto:kontakt@kamieniarstwowisniewski.pl" class="text-gray-700 hover:c-cherry transition-colors link-hover-fill text-nowrap">
                        Email: kontakt@kamieniarstwowisniewski.pl
                    </a>
                </li>
            </ul>
        </div>

    </div>

    <hr class="border-gray-700 my-8">

    {# --- STOPKA DOLNA --- #}
    <div class="flex flex-col sm:flex-row justify-between items-center text-sm c-ink gap-4">
        <p class="mb-0 text-center sm:text-left">
            &copy; <span id="currentYear">{{ "now"|date("Y") }}</span> Kamieniarstwo Wiśniewski. Wszelkie prawa zastrzeżone.
        </p>
        
        <div class="flex flex-col sm:flex-row items-center gap-4 sm:gap-6">
            <a href="{{ pages.find('/polityka-prywatnosci').url|default('#') }}" class="hover:text-red transition-colors">Polityka Prywatności</a>
            
            {# --- DESIGN BY --- #}
            <div class="text-gray-500 flex items-center gap-1 mt-2 sm:mt-0">
                <span>design by</span>
                <a href="https://kocietexty.pl" target="_blank" rel="noopener noreferrer" class="font-medium text-gray-700 hover:text-black transition-colors">
                    kocietexty.pl
                </a>
            </div>
        </div>
    </div>
</div>