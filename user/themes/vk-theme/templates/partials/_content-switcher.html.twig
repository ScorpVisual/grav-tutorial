
<section
    class="content-switcher js-content-switcher max-w-7xl mx-auto p-0 md:p-6 lg:p-8"
    data-content-items='{{ product_addons|json_encode|raw }}'
>
    {# ZMIANA TUTAJ: Dodano klasę "items-start", aby wyrównać kolumny do góry #}
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-start">
        {# LEWA KOLUMNA #}
        <div class="md:col-span-1">
            <h2 class="text-xl md:text-2xl font-bold mb-8 underline--cherry">Galanteria nagrobkowa</h2>
            
            <button id="addon-drawer-trigger" type="button" class="w-full flex justify-between items-center p-4 rounded-lg pick-a-card transition-all duration-300 mb-3">
                <span id="current-addon-name" class="font-bold text-lg">{{ product_addons[0].name }}</span>
                <svg id="addon-drawer-icon" class="w-6 h-6 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
            </button>
            
            <div 
                id="addon-drawer-panel" 
                class="overflow-hidden transition-all duration-500 ease-in-out max-h-0 md:max-h-none md:overflow-visible"
            >
                <div class="flex flex-col gap-3 py-2">
                    {% for addon in product_addons %}
                        <div
                            class="content-switcher__card pick-a-card p-4 rounded-lg cursor-pointer transition-all duration-300 {% if loop.first %}--is-active{% endif %}"
                            data-index="{{ loop.index0 }}"
                            role="button" aria-pressed="{{ loop.first ? 'true' : 'false' }}" tabindex="0"
                        >
                            <h3 class="font-bold text-lg underline--light-grey">{{ addon.name }}</h3>
                            <p class="text-sm ">{{ addon.short_desc }}</p>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
        
        {# PRAWA KOLUMNA #}
        <div class="md:col-span-2">
            <div class="content-switcher__display rounded-lg overflow-hidden h-full flex flex-col lg:p-6 md:min-h-[52rem]">
                <img
                    src="{{ product_addons[0].image }}" alt="{{ product_addons[0].alt_text }}"
                    class="content-switcher__image content-switcher__fade-in w-full h-full object-cover cherry-img-border mb-4 rounded-md"
                >
                <div class="flex flex-col flex-grow gap-4">
                    <h2 class="content-switcher__title content-switcher__fade-in text-3xl font-bold underline--cherry">{{ product_addons[0].title }}</h2>
                    <div class="content-switcher__price-wrapper text-xl md:text-2xl font-bold mt-2">
                        <span class="content-switcher__fade-in"> Cena: <span class="content-switcher__price c-cherry">{{ product_addons[0].price }}</span>
                    </div>
                    <p class="content-switcher__description content-switcher__fade-in text-lg">{{ product_addons[0].full_desc }}</p>
                    <div class="flex flex-col lg:flex-row gap-3 mt-auto">
                        <a href="#szczegoly" class="btn-primary flex-grow text-center">Zobacz realizacje</a>
                        <a href="#kontakt" class="btn-cta flex-grow text-center">Zamów Dodatek</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
