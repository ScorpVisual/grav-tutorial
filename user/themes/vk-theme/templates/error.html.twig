{% extends 'partials/base.html.twig' %}

{% block content %}
    <div class="prose">
        <h1>{{ 'THEME_TAILWIND.ERROR'|t }}</h1>
        {{ page.content|raw }}
    </div>

{% endblock %}

   {# --- Przykładowe dane dla karuzeli produktów --- #}
{# 
  Definicja zmiennej 'products'. 
  W docelowym rozwiązaniu ta zmienna prawdopodobnie będzie przekazywana
  z kontrolera PHP w Grav CMS, a nie definiowana bezpośrednio w szablonie.

