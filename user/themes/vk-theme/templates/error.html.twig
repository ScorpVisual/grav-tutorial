{% extends 'partials/base.html.twig' %}

{% block content %}
<main class="flex flex-col items-center justify-center min-h-[70vh] px-4 text-center w-full">
    <div class="max-w-2xl mx-auto">
        {# Główny nagłówek 404 #}
        <h1 class="text-7xl md:text-9xl font-bold mb-4 custom-error-title">
            404
        </h1>
        
        {# Podtytuł #}
        <h2 class="text-2xl md:text-4xl font-semibold mb-6">
            Ta strona nie istnieje.
        </h2>
        
        {# Opis #}
        <p class="text-base md:text-lg mb-8 max-w-lg mx-auto">
            Przepraszamy, ale adres URL, który wpisałeś, prowadzi donikąd. Strona mogła zostać usunięta, zmieniono jej nazwę lub jest tymczasowo niedostępna.
        </p>
        
        {# Przycisk powrotu - korzysta z wbudowanej zmiennej Grav do adresu głównego #}
        <a href="{{ base_url == '' ? '/' : base_url }}" class="inline-flex items-center justify-center px-8 py-4 font-bold uppercase tracking-wider transition-all duration-300 btn-cta">
            Wróć na stronę główną
        </a>
    </div>
</main>
{% endblock %}