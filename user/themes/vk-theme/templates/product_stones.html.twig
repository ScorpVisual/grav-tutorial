{% extends 'partials/base.html.twig' %}
{% block content %}

{# --- DEFINICJA GRUP KAMIENI (Klucze pasujące do Twojego JSON) --- #}

{# 1. EKONOMICZNE #}
{% set economic_keys = [
    'srebrzysty_strzegomski', 'szary_perlowy', 'roz_srebrzysty', 
    'braz_krolewski', 'china_juparana', 'yellow_queen', 
    'crystal_grey', 'polar_grey'
] %}

{# 2. ŚREDNIE #}
{% set medium_keys = [
    'impala_ciemna', 'impala_indie', 'impala_jasna', 'viscount_white', 
    'padang_dark', 'padang_black', 'steel_grey', 'braz_mysi', 'silver', 
    'nowy_zbik', 'zbik_szary', 'chinska_aurora', 'china_viscount', 
    'tan_brown', 'monte_grey', 'szary_piekny', 'skalisty', 'mwhite', 'astoria'
] %}

{# 3. PREMIUM #}
{% set premium_keys = [
    'star_galaxy', 'angola_black', 'bengal_black', 'ruby_star', 
    'czarny_szwed', 'aurora', 'prada_gold', 'orion', 'orion_silk', 'himalaya_blue'
] %}








{# --- SEKCJA 1: KAMIENIE EKONOMICZNE (TANIE) --- #}
<section id="oferta" class="px-4 py-16 max-w-screen-xl mx-auto">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-start">
    <div class="flex flex-col gap-4 items-stretch">
        <h1 class="text-xl font-bold text-gray-800 mb-4 border-bot-cherry uppercase">
        Kamienie Ekonomiczne
        </h1>
        <div class="text-xl md:text-2xl font-bold price-highlighted">
            Cena: <span class="c-white">Najbardziej przystępna</span>
        </div>
        <div class="text-xl md:text-2xl font-bold price-highlighted bg-ink">
            Dostępność: <span class="c-white">Od ręki</span>
        </div>
        <p class="text-lg text-gray-700 mt-4">
            Grupa kamieni charakteryzujących się dużą dostępnością i przystępną ceną. Ich atrakcyjna cena wynika z efektu skali, ponieważ są to zazwyczaj bardzo popularne granity, wydobywane masowo i sprowadzane w dużych ilościach transportem kontenerowym.
        </p>
        <div class="flex flex-col lg:flex-row gap-3 lg:col-start-1 lg:row-start-4 mt-4">
            <a href="#ekonomiczne" class="btn-primary flex-grow text-center">
                Zobacz dostępne wzory
            </a>
            <a href="#kontakt" class="btn-cta flex-grow text-center">
                Zapytaj o wycenę
            </a>
        </div>
    </div>
    <div>
        <img src="{{ theme_url }}/images/products/stones/stones-main.jpg" alt="Nagrobki z kamieni ekonomicznych" class="w-full object-cover golden-img-border hard-shadow">
    </div>
  </div>
</section>

    {% include 'modular/stones-drawer.html.twig'
        with { group_title: 'Ekonomiczne', group_keys: economic_keys }
    %}
{# Galeria (Statyczna - Twoje stare dane) #}
<section id="ekonomiczne">
{% set popularStonesData = [
    { image_filename: '/images/products/stones/stones-strzegomski-1.jpg', title: 'Granit strzegomski' },
    { image_filename: '/images/products/stones/stones-strzegomski-2.jpg', title: 'Granit strzegomski' },
    { image_filename: '/images/products/stones/stones-strzegomski-3.jpg', title: 'Granit srebrzysty' }
] %}
{% include 'modular/gallery-modular.html.twig' with {'items': popularStonesData} %}
</section>


{# --- SEKCJA 2: KAMIENIE ŚREDNIE (KOMPROMIS) --- #}
<section class="px-4 py-16 max-w-screen-xl mx-auto lg:mt-24">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-start">
    <div>
        <img src="{{ theme_url }}/images/products/stones/stones-features.jpg" alt="Nagrobki z kamieni średniej klasy" class="w-full object-cover golden-img-border hard-shadow">
    </div>
    <div class="flex flex-col gap-4 items-stretch">
        <h2 class="text-xl font-bold text-gray-800 mb-4 border-bot-cherry uppercase">
        Kamienie Premium
        </h2>
        <div class="text-xl md:text-2xl font-bold price-highlighted">
            Cena: <span class="c-white">Najlepszy stosunek ceny do jakości</span>
        </div>
        <div class="text-xl md:text-2xl font-bold price-highlighted bg-ink">
            Dostępność: <span class="c-white">Wysoka</span>
        </div>
        <p class="text-lg text-gray-700 mt-4">
             <strong>Kompromis Cena/Jakość.</strong> Materiały o najlepszym stosunku ceny do jakości. Oferują szlachetniejszy wygląd i bogatszą kolorystykę niż warianty ekonomiczne.
        </p>
        <div class="flex flex-col lg:flex-row gap-3 lg:col-start-1 lg:row-start-4 mt-4">
            <a href="#premium" class="btn-primary flex-grow text-center">
                Zobacz dostępne wzory
            </a>
            <a href="#kontakt" class="btn-cta flex-grow text-center">
                Skontaktuj się
            </a>
        </div>
    </div>
  </div>
</section>

    {% include 'modular/stones-drawer.html.twig'
        with { group_title: 'Premium', group_keys: medium_keys }
    %}

{# Galeria (Statyczna - Twoje stare dane) #}
<section id="premium">
{% set exclusiveStonesData = [
    { image_filename: '/images/products/stones/impala-ciemna.jpg', title: 'Ciemna Impala' },
    { image_filename: '/images/products/stones/stones-exclusive-2.jpg', title: 'White Viscont z paskiem i napisówką z Ciemnej Impali' },
    { image_filename: '/images/products/stones/astoria.jpg', title: 'Astoria' }
] %}
{% include 'modular/gallery-modular.html.twig' with {'items': exclusiveStonesData} %}
</section>



{# --- SEKCJA 3: KAMIENIE PREMIUM (DROGIE) --- #}
<section class="px-4 py-16 max-w-screen-xl mx-auto lg:mt-24">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-start">
    <div class="flex flex-col gap-4 items-stretch">
        <h2 class="text-xl font-bold text-gray-800 mb-4 border-bot-cherry uppercase">
        Kamienie Ekskluzywne
        </h2>
        <div class="text-xl md:text-2xl font-bold price-highlighted">
            Cena: <span class="c-white">Najwyższa</span>
        </div>
        <div class="text-xl md:text-2xl font-bold price-highlighted bg-ink">
            Dostępność: <span class="c-white">Na specjalne zamówienie</span>
        </div>
        <p class="text-lg text-gray-700 mt-4">
             Najdroższe materiały na rynku. Obejmują granity w odcieniach głębokiej czerni oraz unikalne granity egzotyczne. Często są trudnodostępne, ponieważ muszą być importowane z odległych rejonów świata (Indie, Skandynawia, Brazylia).
        </p>
        <div class="flex flex-col lg:flex-row gap-3 lg:col-start-1 lg:row-start-4 mt-4">
            <a href="#kontakt" class="btn-cta flex-grow text-center">
                Zamów wycenę indywidualną
            </a>
        </div>
    </div>
    <div>
        <img src="{{ theme_url }}/images/products/stones/stones-rare.jpg" alt="Ekskluzywne nagrobki premium" class="w-full object-cover golden-img-border hard-shadow">
    </div>
  </div>
</section>
    {% include 'modular/stones-drawer.html.twig'
        with { group_title: 'Ekskluzywne', group_keys: premium_keys }
    %}

{# Galeria (Statyczna - Twoje stare dane) #}
