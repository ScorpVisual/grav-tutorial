{% extends 'partials/base.html.twig' %}

{% block content %}


{# ALL PRODUCTS GRID #}
{% set products = [
    {
        name: "Nagrobek Nowoczesny N-01",
        image: theme_url ~ "/images/placeholders/test-prod/VK-nagrobki-120.jpg",
        alt_text: "Nagrobek nowoczesny z białego granitu",
        price: "od 6 499 PLN",
        link: "#link-do-n01",
        full_desc: "Model N-01 to kwintesencja nowoczesnego designu. Charakteryzuje się prostą bryłą, wysokiej jakości polerowanym granitem i minimalistycznymi akcentami."
    },
    {
        name: "Nagrobek Klasyczny K-08",
        image: theme_url ~ "/images/placeholders/test-prod/VK-nagrobki-124.jpg",
        alt_text: "Nagrobek klasyczny z czarnego granitu",
        price: "od 5 999 PLN",
        link: "#link-do-k08",
        full_desc: "Klasyczny nagrobek K-08 to ponadczasowy wybór, który łączy w sobie tradycyjną formę z doskonałą jakością wykonania. Wykonany z trwałego, czarnego granitu."
    },
    {
        name: "Nagrobek Artystyczny A-12",
        image: theme_url ~ "/images/placeholders/test-prod/VK-nagrobki-129.jpg",
        alt_text: "Nagrobek artystyczny z rzeźbą",
        price: "od 14 999 PLN",
        link: "#link-do-a12",
        full_desc: "Ten model to prawdziwe dzieło sztuki kamieniarskiej. Łączy w sobie różne rodzaje granitu i zawiera ręcznie wykonaną rzeźbę, co czyni go unikalnym projektem."
    },
    {
        name: "Nagrobek Klasyczny K-09",
        image: theme_url ~ "/images/placeholders/test-prod/VK-nagrobki-130.jpg",
        alt_text: "Nagrobek klasyczny z czarnego granitu",
        price: "od 5 999 PLN",
        link: "#link-do-k09",
        full_desc: "Klasyczny nagrobek K-09 to ponadczasowy wybór, który łączy w sobie tradycyjną formę z doskonałą jakością wykonania. Wykonany z trwałego, czarnego granitu."
    },
    {
        name: "Nagrobek Klasyczny K-10",
        image: theme_url ~ "/images/placeholders/test-prod/VK-nagrobki-131.jpg",
        alt_text: "Nagrobek klasyczny z czarnego granitu",
        price: "od 5 999 PLN",
        link: "#link-do-k10",
        full_desc: "Klasyczny nagrobek K-10 to ponadczasowy wybór, który łączy w sobie tradycyjną formę z doskonałą jakością wykonania. Wykonany z trwałego, czarnego granitu."
    }
] %}

{% if products is not empty %}
<section class="py-12 lg:py-20">
    <div class="container mx-auto px-4">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 ">
            {% for product in products %}
            <div class=" golden-img-border">
                <div class="product-card aspect-[3/4]" style="background-image: url('{{ product.image }}');">
                    <div class="product-card__main-content">
                        <h3 class="product-card__title">{{ product.name }}</h3>
                        <p class="product-card__price"><span class="c-pink">Cena:</span> {{ product.price }}</p>
                        <button class="product-card__expand-btn">ROZWIŃ</button>
                    </div>
                    <div class="product-card__details-overlay">
                        <button class="details-overlay__close-btn" aria-label="Zamknij szczegóły">&times;</button>
                        <div class="details-overlay__content">
                            <p class="product-card__desc">{{ product.full_desc }}</p>
                            <div class="product-card__buttons">
                                <a href="{{ product.link }}" class="btn-primary">Zobacz realizacje</a>
                                <a href="#kontakt" class="btn-cta">Zamów wariant</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
</section>
{% endif %}


{% endblock %}