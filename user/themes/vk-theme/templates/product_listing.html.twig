<div class="golden-img-border">
    <div class="product-card aspect-[3/4]" style="background-image: url('{{ theme_url }}{{ product.image }}');">
        
        <div class="product-card__main-content">
            <h3 class="product-card__title">{{ product.name }}</h3>
            <p class="product-card__undertitle">{{ product.short_desc }}</p>

            <p class="product-card__price">
                <span class="c-pink">Cena:</span> {{ product.price }}
            </p>
            <button class="product-card__expand-btn pointer-events-none">ROZWIŃ</button>
        </div>

        <div class="product-card__details-overlay">
            <button class="details-overlay__close-btn" aria-label="Zamknij szczegóły">&times;</button>
            <div class="details-overlay__content">
                
                <h4 class="product-card__title--opened">{{ product.name }}</h4>

                <p class="product-card__desc product-card__desc--overlay" data-role="desc">
                    {{ product.full_desc }}
                </p>

                <div class="product-card__buttons">
                    <a href="{{ base_url_absolute }}{{ product.path }}" class="btn-primary w-full text-center">Sprawdź produkt</a>
                    <a href="#kontakt" class="btn-cta w-full text-center">Zamów wariant</a>
                </div>
            </div>
        </div>

    </div>
</div>

            {% endfor %}
        </div>
    </div>
