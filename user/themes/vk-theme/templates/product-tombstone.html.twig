{% extends 'partials/base.html.twig' %}
{% block content %}

{# Pobranie wszystkich danych z frontmattera (zarządzanych przez blueprint) #}
{% set productVariants = header.product_variants %}
{% set galleryItems = header.gallery_items %}
{% set recommendedGranites = header.recommended_granites %}
{% set product_addons = header.product_addons %}
{% set features = header.features %}
{% set faq_items = header.faq_items %}

{# Sekcja główna produktu #}
<section class="lg:px-4 py-16 max-w-screen-xl mx-auto">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
    <div>
      {% if productVariants[0].img %}
        <img id="product-image"
             src="{{ url(productVariants[0].img) }}"
             alt="{{ header.alt|default('Zdjęcie produktu') }}"
             class="w-full object-cover golden-img-border hard-shadow animated-opacity">
      {% endif %}
    </div>

    <div class="overflow-hidden h-full flex flex-col">
      <div class="p-0 flex flex-col flex-grow gap-4 md:p-6">
        <h2 class="text-3xl font-bold text-gray-800 underline--cherry lg:whitespace-nowrap">
          {{ header.title }}
        </h2>

        {# Przyciski wariantów #}
        {% if productVariants|length > 1 %}
        <div class="flex flex-col justify-around lg:flex-row gap-3">
          {% for variant in productVariants %}
            <button
              type="button"
              class="variant-button btn-tertiary text-center text-gray-600 hover:text-gray-900 shrink-0 whitespace-nowrap {% if loop.first %}is-active{% endif %}"
              data-price="{{ variant.price }}"
              data-desc="{{ variant.full_desc }}"
              data-img="{{ url(variant.img) }}">
              {{ variant.size }}
            </button>
          {% endfor %}
        </div>
        {% endif %}

        {# Cena #}
        <div class="text-xl md:text-2xl font-bold mt-2 price-highlighted">
          Cena: <span class="c-white">od <span id="product-price" class="animated-opacity">{{ productVariants[0].price }}</span> PLN</span>
        </div>

        {# Opis #}
        <p id="product-description" class="min-h-[200px] text-gray-700 text-lg animated-opacity">
          {{ productVariants[0].full_desc }}
        </p>

        <div class="flex flex-col lg:flex-row gap-3 mt-auto">
          <a href="#szczegoly" class="btn-primary flex-grow text-center">
            Zobacz realizacje
          </a>
          <a href="#kontakt" class="btn-cta flex-grow text-center">
            Zamów produkt
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

{# Galeria #}
<section id="szczegoly">
  <div class="lg:p-6">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {% for item in galleryItems %}
        <div class="relative w-full h-64 rounded-lg shadow-lg overflow-hidden pale-img-border product-img cursor-pointer">
          <img src="{{ url(item.image_filename) }}"
               alt="{{ item.title }}"
               class="w-full h-full object-cover">
          <div class="absolute inset-0 flex flex-col items-center justify-center p-4 text-white bg-black bg-opacity-20">
            <span class="product-img__mini--check text-lg font-bold tracking-widest">OBEJRZYJ</span>
            <div class="product-img__mini--title mt-2 text-xl font-semibold">{{ item.title }}</div>
          </div>
        </div>
      {% else %}
        <p class="col-span-full text-center text-gray-500">Obecnie brak zdjęć w galerii.</p>
      {% endfor %}
    </div>
  </div>
</section>


{# Dodatki (Content Switcher) #}
{% if product_addons %}
    {% include 'modular/_content-switcher.html.twig' with { product_addons: product_addons } %}
{% endif %}

{# Cechy produktu #}
<section class="py-8 lg:py-16">
  <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8 ">
    <div class="max-w-4xl mx-auto">
        <h1 class="text-3xl font-bold text-gray-800 mb-4 border-bot-cherry text-center">
            Cechy produktu
        </h1>
        <p class="text-center">
            Specjalizujemy się w pracach cmentarnych, budowie nagrobków i renowacji pomników.
            Skontaktuj się w celu zapoznania się z pełną ofertą naszych usług.
        </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 gap-y-8 py-8 lg:py-16">
      {% for feature in features %}
        <div class="p-4 flex flex-col items-center text-center h-full article-card hover-up-4">
            <div class="flex-shrink-0 my-auto">
                <div class="flex items-start justify-center h-16 w-16">
                    <img src="{{ url(feature.icon) }}" alt="{{ feature.alt }}">
                </div>
            </div>
            
            <h3 class="text-xl font-semibold text-ink mb-3 min-h-[3.5rem] flex items-center justify-center text-center">
                {{ feature.title }}
            </h3>

            <hr class="w-full hr-underline bg-cherry mb-3">
            
            <p class="text-text-brown leading-relaxed grow">
                {{ feature.text }}
            </p>
        </div>
      {% else %}
        <p class="col-span-full text-center text-gray-500">Brak zdefiniowanych cech produktu.</p>
      {% endfor %}
    </div>
</section>

{# FAQ #}
{% if faq_items %}
    {% include 'modular/_faq.html.twig' with { faq_items: faq_items } %}
{% endif %}

{# Modal do galerii #}
{% include 'modular/_gallery_modal.html.twig'%}

{% endblock %}